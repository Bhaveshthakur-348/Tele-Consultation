# CareConnect Portal — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.

# ─── API ──────────────────────────────────────────────────────────────────────
VITE_API_URL=https://api.careconnect.aimed.health

# ─── HIS ──────────────────────────────────────────────────────────────────────
VITE_SAP_URL=https://sap-hana.aimed.health/fhir/R4
VITE_CERNER_URL=https://fhir-ehr.cerner.com/r4

# ─── UAE Health Networks ──────────────────────────────────────────────────────
VITE_NABIDH_URL=https://nabidh.uaehealth.ae/fhir/R4
# Malaffi (Abu Dhabi) or Riayati (Dubai)
VITE_HIE_URL=https://malaffi.ae/fhir/R4

# ─── Video (LiveKit) ──────────────────────────────────────────────────────────
VITE_LIVEKIT_URL=wss://livekit.careconnect.aimed.health

# ─── Auth (Azure AD / Okta SSO) ───────────────────────────────────────────────
VITE_AUTH_URL=https://login.microsoftonline.com/{tenant-id}/oauth2/v2.0
VITE_CLIENT_ID=your-azure-ad-client-id
VITE_REDIRECT_URI=https://careconnect.aimed.health/auth/callback
